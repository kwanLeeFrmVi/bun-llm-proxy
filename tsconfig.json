{
  "compilerOptions": {
    "lib": ["ESNext"],
    "target": "ESNext",
    "module": "Preserve",
    "moduleDetection": "force",
    "jsx": "react-jsx",
    "allowJs": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noPropertyAccessFromIndexSignature": false,
    "baseUrl": ".",
    "paths": {
      "@/lib/usageDb": ["./stubs/usageDb.ts"],
      "@/lib/localDb": ["./db/index.ts"],
      "@/models": [
        "./db/index.ts"
      ],
      "@lib/*": [
        "./lib/*"
      ],
      "@handlers/*": [
        "./handlers/*"
      ],
      "@db/*": [
        "./db/*"
      ],
      "@stubs/*": [
        "./stubs/*"
      ]
    }
  },
  "include": [
    "index.ts",
    "ai-bridge/**/*.ts",
    "db/**/*.ts",
    "handlers/**/*.ts",
    "lib/**/*.ts",
    "routes/**/*.ts",
    "services/**/*.ts",
    "stubs/**/*.ts"
  ]
}
