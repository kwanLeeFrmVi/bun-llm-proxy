    "pm2:delete": "pm2 delete pm2.config.cjs",
    "pm2:logs": "pm2 logs"
  },
  "dependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@types/bun": "latest"
  },
